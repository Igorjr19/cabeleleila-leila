{
  "name": "cabeleleila-leila",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "dev:backend": "pnpm --filter api start:dev",
    "build:backend": "pnpm --filter api build",
    "start:backend": "pnpm --filter api start:prod",
    "test:backend": "pnpm --filter api test",
    "lint:backend": "pnpm --filter api lint",
    "dev:web": "pnpm --filter web start",
    "build:web": "pnpm --filter web build",
    "lint:web": "pnpm --filter web lint",
    "test:web": "pnpm --filter web test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "typescript-eslint": "^8.57.0"
  },
  "lint-staged": {
    "**/*.{js,ts,json,css,scss,html}": "prettier --write",
    "apps/api/**/*.ts": [
      "pnpm --filter api test --passWithNoTests --findRelatedTests"
    ]
  }
}
